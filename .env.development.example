# ============================================================
# EventHub — Development Environment Variables (local)
# Copy to .env for local dev. Do not commit real secrets.
# ============================================================

# --- Core app ---
NODE_ENV=development
PORT=5001
APP_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_BASE_URL=http://localhost:5001

# --- Object storage (recommended: separate DEV bucket/keys) ---
# If these are unset in development, the server falls back to local disk uploads
# under server/uploads and serves them at /uploads.
OBJECT_STORAGE_BUCKET=eventhub-dev-uploads
OBJECT_STORAGE_ENDPOINT=https://your-dev-object-storage-endpoint
OBJECT_STORAGE_ACCESS_KEY_ID=your-dev-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=your-dev-secret-access-key
OBJECT_STORAGE_PUBLIC_BASE_URL=https://your-dev-cdn-base-url
OBJECT_STORAGE_REGION=auto
