# ============================================================
# EventHub — Production Environment Variables
# Copy this file to .env and fill in real values before deploy.
# NEVER commit the .env file with real secrets.
# ============================================================

# --- Database ---
# PostgreSQL connection string (e.g. from Neon, Supabase, or Railway Postgres)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Auth ---
# Random, long secret used to sign JWTs (generate with: openssl rand -hex 64)
JWT_SECRET=your-long-random-jwt-secret

# --- Auth0 ---
AUTH0_DOMAIN=your-auth0-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-auth0-api-identifier

# --- Stripe (use LIVE keys in production) ---
STRIPE_SECRET_KEY=sk_live_your-live-stripe-secret-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-live-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-live-stripe-webhook-signing-secret

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://eventhubglobal.com/api/google/oauth/callback
# 64-character hex string used to encrypt Google access/refresh tokens at rest
# Generate with: openssl rand -hex 32
GOOGLE_TOKEN_ENCRYPTION_KEY=your-64-character-hex-key

# --- Stream Chat ---
STREAM_API_KEY=your-stream-chat-api-key
STREAM_API_SECRET=your-stream-chat-api-secret

# --- Maps ---
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token

# --- Object storage (required for uploads in production) ---
OBJECT_STORAGE_BUCKET=eventhub-prod-uploads
OBJECT_STORAGE_ENDPOINT=https://your-object-storage-endpoint
OBJECT_STORAGE_ACCESS_KEY_ID=your-object-storage-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=your-object-storage-secret-access-key
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.eventhubglobal.com
OBJECT_STORAGE_REGION=auto

# --- App ---
# The canonical public URL of the deployed app
APP_URL=https://eventhubglobal.com

# Frontend build-time API base URL (set this to Railway when frontend is hosted separately)
VITE_API_BASE_URL=https://eventhubrepo-production.up.railway.app

# Comma-separated origins allowed to call API cross-origin
CORS_ALLOWED_ORIGINS=https://eventhubglobal.com,https://www.eventhubglobal.com,https://eventhub-a5700.web.app,https://eventhub-a5700.firebaseapp.com

# --- Email confirmations ---
RESEND_API_KEY=re_live_your-resend-api-key
RESEND_FROM_EMAIL=Event Hub <no-reply@eventhubglobal.com>

# --- Node ---
NODE_ENV=production
PORT=5001
